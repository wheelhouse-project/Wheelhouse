# WheelHouse environment variables -- template
#
# Copy this file to .env and fill in the values you use:  cp .env.example .env
# .env is ignored by git, so your keys never get committed.
#
# These are optional. WheelHouse runs without any of them; they are only
# needed for the specific cloud features noted below.

# Google Gemini API key, for the optional AI text-correction feature.
GEMINI_API_KEY=

# Azure Speech Services, only if you use the Azure speech-to-text provider.
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus

# API key for an OpenAI-compatible AI server, if your server requires one.
# A local server (the default) usually does not.
OPENAI_API_KEY=
