# Pre-built Vulkan wheels (binary, rebuild with scripts/build_vulkan_wheels.sh)
**/vendor/wheels/*.whl

# Python
__pycache__/
*.py[cod]
*.class
.pytest_cache/
test-results.xml

# Virtual environment -- uv creates `.venv/` per service
.venv/
# uv.lock and pyproject.toml are committed; uv cache is global (~/.cache/uv) so
# nothing local to ignore.
.DS_Store
dist/
*.sqlite3
*.log
*.log.[0-9]*
*.egg-info/

# IDE / Editor specific
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/mcp.json
.idea/
*.swp
*.swo
*~
# OS specific
Thumbs.db

# Build artifacts
build/
docs/developers/analysis/
.VSCodeCounter/

# Environment
.env
.env.*
!.env.example

# User config -- personal settings (device addresses, keys, paths).
# Copy services/wheelhouse/config.toml.example to config.toml instead.
# NOTE: config.toml is still tracked today; it gets removed from tracking
# (git rm --cached) at publish time. This rule prevents future re-adds.
services/wheelhouse/config.toml

# Logs
@AutomationLog.txt
bundle.txt
.__wheelhouse.lock

# Telemetry
code_execution_telemetry.jsonl

# WheelHouse specific
services/wheelhouse/WheelHouse.spec
# Generated hints file for sherpa-onnx (filtered from shared/hints.txt)
.hints_filtered.txt

# Sphinx documentation build artifacts
docs/sphinx/build/
docs/sphinx/source/.doctrees/

# Runtime data
stt_usage.csv

# Personal voice patterns (per-machine, merged over the shipped
# speech/config/patterns.toml; .bak/.tmp are Pattern Manager write artifacts)
services/wheelhouse/data/user_patterns.toml
services/wheelhouse/data/user_patterns.toml.bak
services/wheelhouse/data/user_patterns.toml.tmp

# Large Model Files
models/
*.onnx
# ...except the shipped wake-word model: small, tracked, and must survive
# publish staging into the public repo (the 1.0.0 drop,
# wh-export-publish-gitignore-guard)
!services/stt_providers/shared/data/wake_words/*.onnx
tokens.txt

# Claude Code (local settings are user-specific)
.claude/settings.local.json

# Syscheck snapshot (machine-specific, generated by syscheck.py)
syscheck-snapshot.json

# grepai (local semantic search index)
.grepai/*
!.grepai/config.template.yaml
tests/speech/test_smoke_all_patterns.py

# Coverage data
.coverage

# Test artifacts
services/wheelhouse/test_batch_selection_results.json

# TTS corpus (regenerable from generate_corpus.py)
services/stt_providers/evaluation/corpus/**/*.wav
services/stt_providers/evaluation/corpus/**/*.mp3
# Sidecar markers that record the source text used to synthesize each WAV.
services/stt_providers/evaluation/corpus/**/*.txt

# Benchmark results (run-specific, regenerable)
services/stt_providers/evaluation/results/

# Parakeet hotwords file (regenerated from shared/hints.txt at every
# service start, wh-5w04r) and the spoken Zwicky integration fixture
# (per-voice recording, wh-mu6l5).
services/stt_providers/sherpa_offline_parakeet_stt_server/runtime/
services/stt_providers/sherpa_offline_parakeet_stt_server/tests/fixtures/*.wav

# STT benchmark runner artifacts -- large binary model weights
.claude/scans/benchmark-cache/

# STT benchmark sweep -- SMTP credentials and accumulated halt log
# (the .example.toml template is committed; the real secrets file is not)
.claude/scans/benchmark-secrets.toml
.claude/scans/benchmark-sweep.log

# STT scan Task Scheduler output (covered by *.log too; listed for clarity)
.claude/scans/task-scheduler.log

# Superpowers brainstorming sessions
.superpowers/

# Windows artifacts
nul

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
# Dolt is the source of truth; the auto-export is redundant and the
# current bd CLI export caps at ~50 issues, making the file misleading.
# WheelHouse already has export.auto: false in .beads/config.yaml; this
# is belt-and-suspenders in case the setting drifts.
.beads/issues.jsonl

# Semantic search: generated knowledge exports (untracked but grepai-indexed)
# .claude/knowledge-*.md files are intentionally NOT gitignored so grepai can index them

# .claude/worktrees/ holds transient subagent worktrees (some locked,
# some stale). Their .beads/ data files would otherwise show as 700+
# untracked entries in git status.
.claude/worktrees/

# .boss-worktrees/ holds boss-skill worktrees (one per slug). Same
# rationale as .claude/worktrees/: the per-worktree .git pointer and
# any transient state should not appear in the main checkout's git
# status.
.boss-worktrees/

# .tmp/ holds session scratch files (analysis scripts, prompt and review
# dumps, epic text exports, config backups). Transient working data only;
# never committed.
.tmp/

# Codex agent-review-loop scratch dirs and the Codex-side uv cache.
# Each agent-review-loop run creates a per-session .codex-* dir for
# review bodies; they self-empty after the run. The Codex runtime
# points UV_CACHE_DIR at .uv-cache-codex/ so its uv operations do
# not pollute the main uv cache.
.codex-*/
.uv-cache-codex/
# Main uv cache (Codex sometimes writes here too when UV_CACHE_DIR
# is not set).
.uv-cache/

# E2E test scaffold drafted by generate_smoke_tests.py --e2e; the real suite
# (test_e2e_all_patterns.py) is hand-maintained (wh-smoke-generator-crash)
services/wheelhouse/tests/e2e/e2e_all_patterns_scaffold.py
